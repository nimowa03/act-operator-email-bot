# .env.example 파일
# 이 파일은 프로젝트에 필요한 환경 변수 예시를 제공합니다.
# 실제 사용 시에는 이 파일을 복사하여 .env 파일을 만들고 실제 값을 입력해야 합니다.

# Langsmith 프로젝트 추적
# LangSmith는 모니터링 및 디버깅을 위한 도구입니다.
LANGSMITH_PROJECT=act...  # LangSmith에서 사용할 프로젝트 이름
LANGSMITH_API_KEY=lsv2...  # LangSmith API 키 (실제 키로 교체해야 함)

# 선택한 구성에 따라 다음 환경 변수가 필요합니다.

## LLM API 키:
# OpenAI API 키 - GPT 모델을 사용하기 위해 필요합니다.
# OpenAI 웹사이트(https://platform.openai.com/)에서 발급받을 수 있습니다.
OPENAI_API_KEY=sk...

# 기타...
